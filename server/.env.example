# MongoDB Configuration
# Use MongoDB Atlas connection string or local MongoDB instance
MONGO_URL=mongodb://localhost:27017/smartchef
# Example for MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/smartchef

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRY=30d

# Cloudinary Configuration (for image hosting)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# OpenRouter API (for AI recipe generation and ingredient detection)
OPENROUTER_KEY=your_openrouter_api_key

# Twilio Configuration (for SMS-based OTP)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Node Environment
NODE_ENV=development
PORT=8000
